{
  "name": "incircle-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:docker": "vite --host 0.0.0.0 --port 5174",
    "api": "node --no-warnings server/index.js",
    "seed": "node --no-warnings server/index.js --seed-only",
    "migrate:sqlite-to-postgres": "node --no-warnings scripts/migrate-sqlite-to-postgres.mjs",
    "backup:postgres": "node --no-warnings scripts/postgres-backup-restore.mjs",
    "backup:postgres:status": "node --no-warnings scripts/postgres-backup-status.mjs",
    "ops:status": "node --no-warnings scripts/ops-health-check.mjs",
    "launchd:api:install": "node --no-warnings scripts/install-local-api-launchagent.mjs",
    "launchd:api:reload": "node --no-warnings scripts/install-local-api-launchagent.mjs --reload",
    "membership:grant": "node --no-warnings scripts/grant-circle-access.mjs",
    "test:api": "node --no-warnings scripts/api-smoke.mjs",
    "icons:pwa": "node --no-warnings scripts/generate-pwa-icons.mjs",
    "push:vapid": "node --no-warnings scripts/generate-web-push-vapid.mjs",
    "push:send": "node --no-warnings scripts/send-web-push-notifications.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "express": "5.2.1",
    "lucide-react": "0.468.0",
    "pg": "^8.22.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "^6.4.3",
    "web-push": "^3.6.7"
  }
}
