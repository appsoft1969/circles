FROM node:22-bookworm-slim AS build

WORKDIR /app/website
COPY website/package.json website/package-lock.json ./
RUN npm ci

COPY website/index.html website/vite.config.mjs ./
COPY website/src ./src
RUN npm run build

FROM caddy:2-alpine

COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/website/dist /srv/incircle
