# Circles local Docker development defaults.
# Copy to `.env` only when you need to override ports or credentials.

WEB_HOST_PORT=5175
API_HOST_PORT=8788
DATA_STORE=sqlite

POSTGRES_HOST_PORT=5433
POSTGRES_DB=circles_dev
POSTGRES_USER=circles
POSTGRES_PASSWORD=circles_dev_password
ADMINER_HOST_PORT=8081

# Direct local API process can use this when DATA_STORE=postgres.
DATABASE_URL=postgres://circles:circles_dev_password@127.0.0.1:5433/circles_dev

# Docker API service uses this internal service URL when DATA_STORE=postgres.
API_DATABASE_URL=postgres://circles:circles_dev_password@postgres:5432/circles_dev

REDIS_HOST_PORT=6380

MAILPIT_SMTP_HOST_PORT=1025
MAILPIT_WEB_HOST_PORT=8025

MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ROOT_USER=circles
MINIO_ROOT_PASSWORD=circles_minio_password
