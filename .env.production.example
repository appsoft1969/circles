# Copy to `.env.production` on the production server.
# Do not commit real production secrets.

CADDY_ACME_EMAIL=admin@useincircle.app

POSTGRES_DB=incircle
POSTGRES_USER=incircle
POSTGRES_PASSWORD=replace_with_a_long_random_password

# Keep this password in sync with POSTGRES_PASSWORD.
# If the password contains symbols such as @, :, /, or #, URL-encode it.
DATABASE_URL=postgres://incircle:replace_with_a_long_random_password@postgres:5432/incircle
